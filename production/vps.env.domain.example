# Domain mode — Cloudflare DNS for vendas + catalogo on comerc.app.br
# See docs/deployment/vps-shared-host.md

VPS_HOST=YOUR_VPS_IP
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/var/www/fullsales

# App host: API (/v1, /health) + Admin (/admin) + Platform (/platform)
DOMAIN=vendas.comerc.app.br
API_HOST=vendas.comerc.app.br
# Catalog portal host
CATALOG_HOST=catalogo.comerc.app.br
VPS_USE_HTTPS=1

NGINX_HTTP_PORT=80
API_HOST_PORT=8108

POSTGRES_HOST_PORT=5436
REDIS_HOST_PORT=6382
MINIO_API_HOST_PORT=9012
MINIO_CONSOLE_HOST_PORT=9013
