# Root environment — copy to `.env` for local dev (no secrets committed).

# Web client → Rust API (Axum in backend/)
VITE_API_URL=http://127.0.0.1:8080

# Backend (see backend/.env.example for full list)
API_HOST=0.0.0.0
API_PORT=8080

# Seller / Field KMP apps — optional override for API base (default: http://10.0.2.2:8080/v1 on emulator)
# SELLER_API_BASE_URL=http://10.0.2.2:8080/v1
# FIELD_API_BASE_URL=http://10.0.2.2:8080/v1
# Physical device example: http://172.19.2.162:8080/v1
# USB without LAN: adb reverse tcp:8080 tcp:8080
