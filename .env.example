# Root environment — copy to `.env` for local dev (no secrets committed).

# Web client → Rust API (Axum in backend/)
VITE_API_URL=http://127.0.0.1:8080

# Backend (see backend/.env.example for full list)
API_HOST=0.0.0.0
API_PORT=8080

# Seller / Field KMP apps — optional override for API base (default: http://10.0.2.2:8080/v1 on emulator)
# Two common hosts:
#   Emulator → http://10.0.2.2:8080/v1
#   Physical device (LAN) → http://<host-lan-ip>:8080/v1  (e.g. http://192.168.15.15:8080/v1)
# SELLER_API_BASE_URL=http://10.0.2.2:8080/v1
# FIELD_API_BASE_URL=http://10.0.2.2:8080/v1
# Previous LAN example: http://172.19.2.162:8080/v1
# Or persist in apps-mobile/{field,seller}/local.properties (field.api.base.url / seller.api.base.url)
# USB without LAN: adb reverse tcp:8080 tcp:8080
#
# Catalog share URLs come from the API (`GET /v1/me/seller-share` → shareUrl).
# Configure the portal origin on the backend: PORTAL_PUBLIC_ORIGIN=http://<lan-ip>:5175
