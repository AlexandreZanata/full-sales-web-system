#!/usr/bin/env bash
# Fast gate on staged files (secrets, touched-package lint/test, cargo fmt+check).
# Full suite: pre-push + GitHub Actions on push. Skip: SKIP_VERIFY=1 git commit ...
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [[ "${SKIP_VERIFY:-}" == "1" ]]; then
  echo "pre-commit: SKIP_VERIFY=1 — skipping"
  exit 0
fi
exec bash "${ROOT}/scripts/verify-changed.sh" commit
