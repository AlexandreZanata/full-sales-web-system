#!/usr/bin/env bash
# Full local gate before push (lint/test, clippy, cargo test, E2E, mobile).
# Mirrors GitHub CI; skip if you rely on CI only: SKIP_VERIFY=1 git push ...
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [[ "${SKIP_VERIFY:-}" == "1" ]]; then
  echo "pre-push: SKIP_VERIFY=1 — skipping"
  exit 0
fi
exec bash "${ROOT}/scripts/verify-changed.sh" push
