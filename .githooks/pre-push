#!/usr/bin/env bash
# Runs verify-changed on commits being pushed. Skip: SKIP_VERIFY=1 git push ...
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [[ "${SKIP_VERIFY:-}" == "1" ]]; then
  echo "pre-push: SKIP_VERIFY=1 — skipping"
  exit 0
fi
exec bash "${ROOT}/scripts/verify-changed.sh" push
