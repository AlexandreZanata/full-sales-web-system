# Local development — copy to `.env` and adjust.

# PostgreSQL (sqlx migrate + infra-postgres)
DATABASE_ADMIN_URL=postgres://print3d:print3d@localhost:5434/full_sales_dev
DATABASE_URL=postgres://app_user:app_password@localhost:5434/full_sales_dev

# Redis (sessions, cache — Phase 2+)
REDIS_URL=redis://localhost:6380
# CNPJ_NOT_FOUND negative cache uses REDIS_URL when set (TTL 24h, key cnpj-lookup:miss:{cnpj})

# JWT signing secret (Phase 2+)
JWT_SECRET=change-me-in-production-use-long-random-string

# Ed25519 private key seed for signed reports (dev only — matches dev-seed signing key)
REPORT_SIGNING_KEY_HEX=0707070707070707070707070707070707070707070707070707070707070707

# Dev seed guard — required for `pnpm seed:dev`
# ALLOW_DEV_SEED=1

# HTTP server
API_HOST=0.0.0.0
API_PORT=8080

# Public catalog (portal) origin — absolute seller share links (`GET /v1/me/seller-share` → shareUrl)
# Dev on LAN (phones): http://<host-lan-ip>:5175
# PORTAL_PUBLIC_ORIGIN=http://127.0.0.1:5175

# Health monitoring (Phase 9)
# HEALTH_PROBE_INTERVAL_SECS=60
# HEALTH_PROBE_RETENTION_DAYS=30
# HEALTH_ALERT_THRESHOLD=3
# OPS_ALERT_WEBHOOK=https://hooks.slack.com/services/...

# LGPD data export ZIP bucket (Phase 10)
# EXPORT_BUCKET=exports

# Object storage (MinIO / S3 — required for media + readiness probe when set)
# STORAGE_ENDPOINT=http://127.0.0.1:9000
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_BUCKET=full-sales-media
# STORAGE_REGION=us-east-1

# Logging
RUST_LOG=api_http=info,tower_http=info

# PlatformAdmin MFA — set to 1 in local dev to skip TOTP (never in production)
# PLATFORM_MFA_DISABLED=1

# CNPJ lookup upstream (Phase 70 — default brasilapi; use opencnpj in production)
# CNPJ_LOOKUP_PROVIDER=brasilapi
# CNPJ_LOOKUP_URL=https://api.comerc.app.br
# CNPJ_LOOKUP_API_KEY=ocnpj_live_<32-hex>   # required when CNPJ_LOOKUP_PROVIDER=opencnpj

# Asaas — platform billing (Phase 3+; sandbox: https://sandbox.asaas.com)
# ASAAS_API_KEY=$aact_YOUR_SANDBOX_KEY
# ASAAS_WEBHOOK_TOKEN=whsec_min_32_chars_no_spaces_not_api_key
# ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# ASAAS_TIMEOUT_SECS=15
# ASAAS_MAX_RETRIES=3
# ASAAS_CIRCUIT_THRESHOLD=5
