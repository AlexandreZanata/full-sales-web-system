# Local development — copy to `.env` and adjust.

# PostgreSQL (sqlx migrate + infra-postgres)
DATABASE_URL=postgres://print3d:print3d@localhost:5434/full_sales_dev

# Redis (sessions, cache — Phase 2+)
REDIS_URL=redis://localhost:6380

# JWT signing secret (Phase 2+)
JWT_SECRET=change-me-in-production-use-long-random-string

# Ed25519 private key seed, base64 (Phase 5+)
ED25519_PRIVATE_KEY=

# HTTP server
API_HOST=0.0.0.0
API_PORT=8080

# Logging
RUST_LOG=api_http=info,tower_http=info
