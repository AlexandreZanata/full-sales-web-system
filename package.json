{
  "name": "full-sales-web-system",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm verify:backend",
    "verify:backend": "cd backend && cargo fmt --check && cargo clippy --workspace -- -D warnings && cargo test --workspace",
    "dev": "pnpm --parallel --filter @full-sales/api --filter @full-sales/web dev",
    "dev:web": "pnpm --filter @full-sales/web dev",
    "dev:api": "pnpm --filter @full-sales/api dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
