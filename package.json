{
  "name": "full-sales-web-system",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test e2e/admin-login.spec.ts e2e/admin-orders.spec.ts e2e/admin-mobile.spec.ts",
    "test:e2e:portal": "playwright test e2e/portal-*.spec.ts --config=playwright.portal.config.ts",
    "test:e2e:field": "playwright test e2e/field-*.spec.ts --config=playwright.field.config.ts",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm verify:backend",
    "verify:backend": "cd backend && cargo fmt --check && cargo clippy --workspace -- -D warnings && cargo test --workspace",
    "validate:openapi": "npx --yes @apidevtools/swagger-cli validate docs/openapi.yaml",
    "dev": "pnpm --parallel --filter @full-sales/api --filter @full-sales/web --filter @full-sales/admin --filter @full-sales/portal --filter @full-sales/field --filter @full-sales/platform-admin dev",
    "dev:frontends": "pnpm --parallel --filter @full-sales/web --filter @full-sales/admin --filter @full-sales/portal --filter @full-sales/field --filter @full-sales/platform-admin dev",
    "dev:web": "pnpm --filter @full-sales/web dev",
    "dev:api": "pnpm --filter @full-sales/api dev",
    "dev:admin": "pnpm --filter @full-sales/admin dev",
    "dev:portal": "pnpm --filter @full-sales/portal dev",
    "dev:field": "pnpm --filter @full-sales/field dev",
    "dev:platform-admin": "pnpm --filter @full-sales/platform-admin dev",
    "mobile:seller:check": "cd apps-mobile/seller && ./gradlew :shared:check :composeApp:compileDebugKotlinAndroid :androidApp:lint :androidApp:assembleDebug",
    "seed:dev": "cd backend && ALLOW_DEV_SEED=1 cargo run -p dev-seed",
    "seed:dev:reset": "bash backend/crates/dev-seed/scripts/reset-dev-catalog.sh",
    "validate:deploy": "bash deploy/scripts/validate-deploy.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
