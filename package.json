{
  "name": "full-sales-web-system",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test e2e/admin-login.spec.ts e2e/admin-orders.spec.ts e2e/admin-mobile.spec.ts",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm verify:backend",
    "verify:backend": "cd backend && cargo fmt --check && cargo clippy --workspace -- -D warnings && cargo test --workspace",
    "validate:openapi": "npx --yes @apidevtools/swagger-cli validate docs/openapi.yaml",
    "dev": "pnpm --parallel --filter @full-sales/api --filter @full-sales/web --filter @full-sales/admin dev",
    "dev:web": "pnpm --filter @full-sales/web dev",
    "dev:api": "pnpm --filter @full-sales/api dev",
    "dev:admin": "pnpm --filter @full-sales/admin dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
