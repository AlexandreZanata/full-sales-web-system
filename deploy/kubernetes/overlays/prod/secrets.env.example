# Production uses managed Postgres/Redis/object storage (OD-15-4).
# Copy to secrets.env (gitignored) and inject via CI — never commit real values.
DATABASE_URL=postgres://app:REPLACE@managed-postgres:5432/full_sales
DATABASE_ADMIN_URL=postgres://admin:REPLACE@managed-postgres:5432/full_sales
POSTGRES_PASSWORD=unused-in-prod-managed
REDIS_URL=redis://managed-redis:6379
JWT_SECRET=REPLACE-WITH-CI-SECRET
REPORT_SIGNING_KEY_HEX=REPLACE-WITH-CI-SECRET
STORAGE_ENDPOINT=https://s3.example.com
STORAGE_ACCESS_KEY=REPLACE
STORAGE_SECRET_KEY=REPLACE
ASAAS_API_KEY=REPLACE
ASAAS_WEBHOOK_TOKEN=REPLACE
BILLING_CREDENTIALS_MASTER_KEY=REPLACE
