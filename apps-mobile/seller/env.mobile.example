# Seller Android — copy to `.env.mobile` (gitignored).
# VPS / production API (same-origin on vendas.comerc.app.br):

SELLER_API_BASE_URL=https://vendas.comerc.app.br/v1
SELLER_RELEASE_API_BASE_URL=https://vendas.comerc.app.br/v1

# Public catalog portal (share / open catalog link in the app)
SELLER_CATALOG_BASE_URL=https://catalogo.comerc.app.br
SELLER_RELEASE_CATALOG_BASE_URL=https://catalogo.comerc.app.br

# Local emulator alternative:
# SELLER_API_BASE_URL=http://10.0.2.2:8080/v1
